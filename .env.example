# HR Platform Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE CONFIGURATION (for local development)
# ============================================================================
# PostgreSQL connection details for local IDE runs (outside Docker)

# Database URL - format: jdbc:postgresql://HOST:PORT/DATABASE_NAME
DB_URL=jdbc:postgresql://localhost:5432/hr_platform

# Database username
DB_USERNAME=postgres

# Database password
DB_PASSWORD=postgres

# ============================================================================
# DOCKER POSTGRESQL CONFIGURATION
# ============================================================================
# These variables are used by Docker Compose to configure the PostgreSQL container

# Database name to create in PostgreSQL
POSTGRES_DB=hr_platform

# PostgreSQL root user
POSTGRES_USER=postgres

# PostgreSQL password for root user
POSTGRES_PASSWORD=postgres

# ============================================================================
# NOTES
# ============================================================================
#
# LOCAL DEVELOPMENT:
#   1. Ensure PostgreSQL is installed and running
#   2. Create a database called 'hr_platform' (or use existing)
#   3. Fill in DB_URL, DB_USERNAME, DB_PASSWORD
#   4. Run: ./mvnw spring-boot:run
#
# DOCKER DEVELOPMENT:
#   1. Docker and Docker Compose must be installed
#   2. Fill in POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD
#   3. Run: docker-compose up --build
#   4. The database will be created automatically
#
# DEFAULT VALUES:
#   - Database: hr_platform
#   - User: postgres
#   - Password: postgres
#   - Host: localhost (local) or db (Docker)
#   - Port: 5432
#
